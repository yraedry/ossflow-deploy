# GitHub owner (usuario o organización)
GITHUB_OWNER=yraedry

# Versiones de las imágenes (usar "latest" o tags específicos como "v1.0.0")
BACKEND_VERSION=latest
FRONTEND_VERSION=latest

# Token del túnel de Cloudflare Zero Trust
# Obtener en: https://one.dash.cloudflare.com → Networks → Tunnels → Create tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# Directorio de datos SQLite en el host (prod)
# Se crea automáticamente si no existe
SQLITE_DATA_DIR=/var/lib/ossflow/data
